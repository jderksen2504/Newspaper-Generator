# ============================================================================
# Desktop-App (Tauri, im desktop/ Unterverzeichnis)
# ============================================================================

# Tauri Build-Artifacts
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/dist/

# Self-hosted Web-Fonts (werden via `node scripts/download-fonts.js` gezogen)
desktop/src/fonts/*.woff2
desktop/src/fonts/*.ttf
desktop/src/fonts/*.woff

# Tauri-spezifische Dependencies
desktop/node_modules/
desktop/src-tauri/sidecars/playwright-export/node_modules/

# Playwright-Cache
desktop/playwright-cache/
desktop/.cache/

# Tauri Build-Tools
desktop/src-tauri/WixTools/
desktop/src-tauri/.tauri/

# ============================================================================
# Sandbox-Intern (nicht pushen)
# ============================================================================

# Skills directory (Sandbox-Feature)
/skills/

# Uploads/Downloads (Sandbox-Dateiablage)
/upload/
/download/
/scripts/*.png
/scripts/*.json

# Sandbox-Konfiguration
/Caddyfile
/examples/
/prisma/
/db/
bun.lock
# Sandbox-Scripts (nicht pushen)
/.zscripts/
/.env
