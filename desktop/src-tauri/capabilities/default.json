{
  "$schema": "https://schema.tauri.app/acl/2",
  "identifier": "default",
  "description": "Default permission set for the Newspaper Generator",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:image:default",
    "core:menu:default",
    "core:tray:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file"
  ]
}
