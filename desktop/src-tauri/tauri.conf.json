{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Newspaper Generator",
  "version": "1.4.1",
  "identifier": "com.dnd.newspaper-generator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Newspaper Generator — D&D Setting",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "focus": true,
        "backgroundColor": "#1c1917"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-inline'; connect-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**", "$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "resources": ["sidecars/playwright-export/**/*"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "shortDescription": "Newspaper Generator für D&D Kampagnen",
    "longDescription": "Erstelle historische Zeitungsartikel für deine D&D-Kampagne. Mit Live-Vorschau, JSON-Speicherung und hochwertigem PNG-Export via Headless Chromium.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English", "German"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {}
}
