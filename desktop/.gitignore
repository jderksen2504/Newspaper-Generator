# Build artifacts
# ============================================================================
dist/
src-tauri/target/
src-tauri/gen/

# ============================================================================
# Self-hosted Web-Fonts (werden via `node scripts/download-fonts.js` gezogen)
# Nicht einchecken — sie sind ~1 MB und ändern sich selten, aber sie gehören
# nicht ins Repo, da sie via Build-Skript reproduzierbar sind.
# ============================================================================
src/fonts/*.woff2
src/fonts/*.ttf
src/fonts/*.woff

# ============================================================================
# Playwright Cache (lokal, wenn man `npx playwright install chromium` laufen lässt)
# ============================================================================
playwright-cache/
.cache/

